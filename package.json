{
  "name": "google-calendar-mcp-stateless",
  "version": "1.0.0",
  "description": "Stateless Google Calendar MCP Proxy for n8n",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "google-calendar-mcp": "build/index.js"
  },
  "files": [
    "build/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "google-calendar",
    "n8n"
  ],
  "private": true,
  "scripts": {
    "start": "node build/index.js",
    "build": "node scripts/build.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "gaxios": "^7.1.3",
    "google-auth-library": "^10.5.0",
    "googleapis": "^171.4.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "esbuild": "^0.27.2",
    "typescript": "^5.3.3"
  }
}
